AGENTMESH_DB_PATH=data/agentmesh.sqlite3
AGENTMESH_PORT=8010
AI_API_URL=https://modelservice.jdcloud.com/v1/responses
AI_MODEL=Gemini-3-Flash-Preview
AI_API_KEY=replace-with-your-key
AGENTMESH_LLM_BASE_URL=https://modelservice.jdcloud.com/v1/
AGENTMESH_LLM_MODEL=GPT-5.5
AGENTMESH_LLM_API_KEY=replace-with-your-key
AGENTMESH_CHAT_LLM_TIMEOUT_SECONDS=2.5
AGENTMESH_LLM_TIMEOUT_SECONDS=30
AGENTMESH_LLM_CONNECT_TIMEOUT_SECONDS=5
AGENTMESH_WEB_PROVIDER=
AGENTMESH_OPENCLI_COMMAND=opencli
AGENTMESH_OPENCLI_COMMAND_TEMPLATE=
AGENTMESH_AGENT_BROWSER_COMMAND=agent-browser
AGENTMESH_AGENT_BROWSER_COMMAND_TEMPLATE=
# Oxygen-CLI internal provider (auth is handled by the installed CLI's own login state)
AGENTMESH_O2_RESEARCH_ENABLED=false
AGENTMESH_O2_RESEARCH_CLI=metasearch
AGENTMESH_O2_DATA_ENABLED=false
AGENTMESH_O2_DATA_CLI=metasearch
AGENTMESH_O2_METASEARCH_ENDPOINT=https://agentkits-a2a-gateway.jd.com/agents/sku-search
AGENTMESH_DATA_API_URL=
AGENTMESH_DATA_API_KEY=
AGENTMESH_DATA_API_TIMEOUT_SECONDS=20
AGENTMESH_OAUTH_ENABLED=false
AGENTMESH_OAUTH_PROVIDER=corporate_oauth
AGENTMESH_OAUTH_AUTHORIZE_URL=
AGENTMESH_OAUTH_TOKEN_URL=
AGENTMESH_OAUTH_USERINFO_URL=
AGENTMESH_OAUTH_CLIENT_ID=
AGENTMESH_OAUTH_CLIENT_SECRET=
AGENTMESH_OAUTH_REDIRECT_URI=http://127.0.0.1:8010/api/auth/oauth/callback
AGENTMESH_OAUTH_SCOPE=openid profile email
AGENTMESH_OAUTH_DEFAULT_ROLE=user
AGENTMESH_AUTO_POST_WORKER_ENABLED=false
AGENTMESH_AUTO_POST_WORKER_INTERVAL_SECONDS=30
